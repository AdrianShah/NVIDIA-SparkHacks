# Backend environment variables - copy to .env and source before running
MOCK_MODE=false

# ── NVIDIA NIM (local inference on DGX Spark) ─────────────────────────────────
# Start NIM: docker run --gpus all -p 8000:8000 nvcr.io/nim/meta/llama-3.2-11b-vision-instruct:latest
LOCAL_LLM_URL=http://localhost:8000/v1
LOCAL_LLM_MODEL=meta/llama-3.2-11b-vision-instruct

# ── Data ──────────────────────────────────────────────────────────────────────
DATA_DIR=./backend/data

# -- Environmental risk feeds ------------------------------------------------
# TRCA floodplain point checks refresh hourly. Use 1800 for a 30-minute demo interval.
TRCA_FLOOD_CACHE_TTL_SECONDS=3600
WEATHER_CACHE_TTL_SECONDS=300
ENVIRONMENTAL_RISK_TIMEOUT_SECONDS=4
